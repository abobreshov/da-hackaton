# backend/.env.example — copy to .env and fill in
#
# NestJS backend: domain tables (Drizzle). HTTP (PORT) + TCP microservice (TCP_PORT).
# Validates tokens by TCP-calling auth-service. Generate secrets: openssl rand -hex 24
# dev.sh (Docker) ignores this file. dev-local.sh reads it first.

# --- Transport
PORT=3004
TCP_PORT=4004
TCP_BIND=127.0.0.1          # dev-local: 127.0.0.1 / docker: 0.0.0.0
NODE_ENV=development

# --- Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/appdb

# --- auth-service RPC (TCP)
AUTH_TCP_HOST=127.0.0.1
AUTH_TCP_PORT=4003

# --- Redis (BullMQ queues)
REDIS_HOST=127.0.0.1
REDIS_PORT=6380

# --- Shared secret (MUST match auth-service + bff; openssl rand -hex 24)
SYSTEM_KEY=REPLACE_ME_32_CHARS

# --- CORS / logging
ALLOWED_ORIGINS=http://localhost:3006,http://localhost:3007
LOG_LEVEL=info

# --- Attachments + retention
ATTACHMENTS_DIR=./data/attachments
MESSAGE_RETENTION_DAYS=30
ATTACHMENT_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=30
ABUSE_REPORT_RETENTION_DAYS=30

# --- Inter-service mTLS
TLS_ENABLED=true
TLS_CA_PATH=../../secrets/internal-ca/ca.crt
TLS_CERT_PATH=../../secrets/internal-ca/backend.crt
TLS_KEY_PATH=../../secrets/internal-ca/backend.key
