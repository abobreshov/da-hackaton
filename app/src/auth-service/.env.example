# auth-service/.env.example — copy to .env and fill in
#
# NestJS auth-service: HTTP (PORT) + TCP microservice (TCP_PORT) hybrid.
# Hot-path secrets must be >= 32 chars. Generate with: openssl rand -hex 24
# dev.sh (Docker) ignores this file — values are baked into docker-compose.dev.yml.
# dev-local.sh reads this file first, then script-exported overrides win.

# --- Transport
PORT=3003
TCP_PORT=4003
TCP_BIND=127.0.0.1          # dev-local: 127.0.0.1 / docker: 0.0.0.0
NODE_ENV=development

# --- Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/appdb

# --- Redis (refresh-token store)
REDIS_HOST=localhost
REDIS_PORT=6380

# --- Secrets (>= 32 chars each; openssl rand -hex 24)
JWT_ADMIN_SECRET=REPLACE_ME_32_CHARS
JWT_CUSTOMER_SECRET=REPLACE_ME_32_CHARS
SYSTEM_KEY=REPLACE_ME_32_CHARS   # MUST match bff + backend

# --- JWT lifetimes
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=24h
SESSION_MAX_DURATION_DAYS=7

# --- CORS / policy
ALLOWED_ORIGINS=http://localhost:3007
ALLOW_PASSWORD_ONLY_ADMIN_LOGIN=false

# --- SMTP (dev uses Mailpit on localhost:1025; web UI at http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@local

# --- Inter-service mTLS (set TLS_ENABLED=true; certs from ./scripts/gen-certs.sh)
TLS_ENABLED=true
TLS_CA_PATH=../../secrets/internal-ca/ca.crt
TLS_CERT_PATH=../../secrets/internal-ca/auth-service.crt
TLS_KEY_PATH=../../secrets/internal-ca/auth-service.key
