# frontend/.env.example — copy to .env and fill in
#
# Vite reads BFF_URL / VITE_BFF_URL for the dev proxy (see vite.config.ts).
# Use dev-local mode default below; for Docker the value comes from compose.

# --- BFF endpoint (dev-local: localhost:3006)
BFF_URL=http://localhost:3006

# --- Optional overrides when host ports 3006/3007 are taken
# VITE_PORT=13007
# VITE_BFF_URL=http://localhost:13006
