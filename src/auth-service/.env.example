PORT=3003
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/appdb
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_ADMIN_SECRET=change-me-admin-secret-min-32-characters
JWT_CUSTOMER_SECRET=change-me-customer-secret-min-32-chars
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=24h
SESSION_MAX_DURATION_DAYS=7
ALLOWED_ORIGINS=http://localhost:3007
ALLOW_PASSWORD_ONLY_ADMIN_LOGIN=false
