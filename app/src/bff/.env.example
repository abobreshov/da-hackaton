# bff/.env.example — copy to .env and fill in
#
# NestJS BFF: browser-facing (cookies) + TCP client to auth-service and backend.
# All three cookie/JWT secrets must be >= 32 chars. Generate: openssl rand -hex 24
# dev.sh (Docker) ignores this file. dev-local.sh reads it first.

# --- Transport
PORT=3006
NODE_ENV=development
LOG_LEVEL=debug

# --- Upstream TCP (auth-service + backend)
AUTH_TCP_HOST=127.0.0.1
AUTH_TCP_PORT=4003
BACKEND_TCP_HOST=127.0.0.1
BACKEND_TCP_PORT=4004

# --- Secrets (>= 32 chars each; openssl rand -hex 24)
JWT_SECRET=REPLACE_ME_32_CHARS             # BFF-issued tokens
SESSION_COOKIE_SECRET=REPLACE_ME_32_CHARS  # JWT signer for session cookie payload
COOKIE_SECRET=REPLACE_ME_32_CHARS          # @fastify/cookie HMAC wrapper
SYSTEM_KEY=REPLACE_ME_32_CHARS             # MUST match auth-service + backend

# --- Cookie TTLs (seconds)
SESSION_COOKIE_TTL=3600
REFRESH_COOKIE_TTL=172800

# --- CORS / WebSocket origins
ALLOWED_ORIGINS=http://localhost:3007
ALLOWED_WS_ORIGINS=http://localhost:3007

# --- Reverse-proxy allowlist (comma-separated IPs / CIDR blocks, or 'loopback').
# Production-only. Empty → loopback-only. NEVER set to a bare wildcard.
# TRUSTED_PROXIES=10.0.0.0/8

# --- Cookie Secure opt-out (dev only — plain HTTP). Never enable in staging/prod.
COOKIE_SECURE_DISABLED=true

# --- Inter-service mTLS (client-side cert)
TLS_ENABLED=true
TLS_CA_PATH=../../secrets/internal-ca/ca.crt
TLS_CERT_PATH=../../secrets/internal-ca/bff.crt
TLS_KEY_PATH=../../secrets/internal-ca/bff.key
