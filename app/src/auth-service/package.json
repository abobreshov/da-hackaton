{
  "name": "@app/auth-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed": "ts-node --project tsconfig.json -r tsconfig-paths/register scripts/seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@app/contracts": "workspace:*",
    "@fastify/cookie": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/microservices": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "bcrypt": "^5.1.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "ioredis": "^5.6.0",
    "nodemailer": "^8.0.5",
    "otplib": "^12.0.1",
    "pg": "^8.16.0",
    "pino": "^9.0.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/ioredis-mock": "^8",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.0.0",
    "@types/qrcode": "^1.5.0",
    "drizzle-kit": "^0.30.0",
    "ioredis-mock": "^8.13.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "rootDir": ".",
    "testMatch": [
      "<rootDir>/src/**/*.spec.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "<rootDir>/tsconfig.json"
        }
      ]
    }
  }
}
