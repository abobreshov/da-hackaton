FROM node:22-alpine
RUN corepack enable && corepack prepare yarn@4.9.1 --activate
WORKDIR /app
# Build context is the yarn workspace root (see docker-compose.dev.yml). Copy
# the whole tree so workspace: protocol deps (@app/contracts) resolve on
# install. Bind mounts in compose overlay `src/**/src` for hot-reload.
COPY . .
RUN yarn install --no-immutable
# @app/contracts is consumed via `main` + `types` (dist/*); service tsconfigs
# use `moduleResolution: node` and won't read the `exports.default` src path.
# Build the workspace dep once so service tsc --watch can resolve it.
RUN yarn workspace @app/contracts build
WORKDIR /app/src/auth-service
CMD ["yarn", "nest", "start", "--watch"]
